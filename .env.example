# Database
POSTGRES_DB=devtrackr
POSTGRES_USER=devtrackr_user
POSTGRES_PASSWORD=changeme

# Backend
NODE_ENV=development
PORT=5000
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=24h

# Database URL (used by backend)
DATABASE_URL=postgresql://devtrackr_user:changeme@postgres:5432/devtrackr

# GitHub OAuth (create at github.com/settings/developers → OAuth Apps)
GITHUB_TOKEN=your_personal_access_token_here
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# Frontend
REACT_APP_API_URL=http://localhost:5000
